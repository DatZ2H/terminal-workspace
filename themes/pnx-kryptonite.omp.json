{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "console_title_template": "\ue0b6 {{ .Folder }}",
  "blocks": [
    {
      "alignment": "left",
      "segments": [
        {
          "foreground": "#444444",
          "style": "plain",
          "template": "\u256d\u2500",
          "type": "text"
        },
        {
          "background": "#444444",
          "foreground": "#00f2ff",
          "leading_diamond": "\ue0b6",
          "style": "diamond",
          "template": "{{ if .SSHSession }}\ueba9 {{ end }}\uf489 {{ .UserName }}",
          "type": "session"
        },
        {
          "background": "#00c3ff",
          "foreground": "#ffffff",
          "powerline_symbol": "\ue0b0",
          "properties": {
            "style": "agnoster_short",
            "max_depth": 3
          },
          "style": "powerline",
          "template": " \uf07c {{ .Path }} ",
          "type": "path"
        },
        {
          "background": "#ffff66",
          "background_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}#ff004c{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}#c678dd{{ end }}",
            "{{ if gt .Ahead 0 }}#00ff9c{{ end }}",
            "{{ if gt .Behind 0 }}#ffff66{{ end }}"
          ],
          "foreground": "#141414",
          "powerline_symbol": "\ue0b0",
          "properties": {
            "branch_icon": "\ue725 ",
            "fetch_status": true,
            "fetch_upstream_icon": true
          },
          "style": "powerline",
          "template": " {{ .UpstreamIcon }}{{ .HEAD }}{{ if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }} \uf044 {{ .Working.String }}{{ end }}{{ if and (.Working.Changed) (.Staging.Changed) }} |{{ end }}{{ if .Staging.Changed }} \uf046 {{ .Staging.String }}{{ end }}{{ if gt .StashCount 0 }} \ueb4b {{ .StashCount }}{{ end }} ",
          "type": "git"
        },
        {
          "background": "#444444",
          "background_templates": [
            "{{ if gt .Code 0 }}#ff004c{{ end }}"
          ],
          "foreground": "#d4d4d4",
          "foreground_templates": [
            "{{ if gt .Code 0 }}#141414{{ end }}"
          ],
          "properties": {
            "always_enabled": true
          },
          "style": "diamond",
          "template": " {{ if gt .Code 0 }}\uf00d {{ .Code }}{{ else }}\uf00c{{ end }} ",
          "trailing_diamond": "\ue0b4",
          "type": "status"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "right",
      "segments": [
        {
          "foreground": "#ffff99",
          "style": "plain",
          "template": "\uf253 {{ .FormattedMs }}",
          "type": "executiontime",
          "properties": {
            "threshold": 500,
            "style": "austin"
          }
        },
        {
          "foreground": "#33f5ff",
          "style": "plain",
          "template": " \ue718 {{ .Full }}",
          "type": "node"
        },
        {
          "foreground": "#33d6ff",
          "style": "plain",
          "template": " \uf412 {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }}",
          "type": "dotnet"
        },
        {
          "foreground": "#33ffb0",
          "style": "plain",
          "template": " \ue235 {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }}",
          "type": "python"
        },
        {
          "foreground": "#444444",
          "style": "plain",
          "template": " \u2502 ",
          "type": "text"
        },
        {
          "foreground": "#d898e8",
          "properties": {
            "time_format": "15:04:05"
          },
          "style": "plain",
          "template": "\uf43a {{ .CurrentDate | date .Format }}",
          "type": "time"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "foreground": "#444444",
          "style": "plain",
          "template": "\u2570\u2500",
          "type": "text"
        },
        {
          "foreground": "#ff004c",
          "style": "plain",
          "template": "\ue00a ",
          "type": "root"
        },
        {
          "foreground": "#00c3ff",
          "foreground_templates": [
            "{{ if gt .Code 0 }}#ff004c{{ end }}"
          ],
          "style": "plain",
          "template": "\ue285 ",
          "type": "status",
          "properties": {
            "always_enabled": true
          }
        }
      ],
      "type": "prompt"
    }
  ],
  "final_space": true,
  "version": 4
}
